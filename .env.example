# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Local (Docker Compose):
# DATABASE_URL=postgresql://admin:admin@db:5432/delivery_db
# Produção (Supabase — copie a "Connection string" do painel do Supabase):
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role_key>

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=your_verified_sender@domain.com

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-chave-segura-em-producao

# ─── Login Social ─────────────────────────────────────────────────────────────
PROVISIONAL_TOKEN_SECRET=troque-por-outra-chave-segura
PROVISIONAL_TOKEN_TTL=15
SOCIAL_REQUEST_TIMEOUT=5

# ─── CORS (produção) ──────────────────────────────────────────────────────────
# Coloque a URL exata do seu frontend Vercel (sem barra no final).
# Para múltiplas origens, separe por vírgula:
# ALLOWED_ORIGINS=https://zupps-eats.vercel.app,https://meu-dominio.com
ALLOWED_ORIGINS=https://zupps-eats.vercel.app

# ─── Frontend (geração de links em e-mails) ───────────────────────────────────
FRONTEND_URL=https://zupps-eats.vercel.app

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=TEST-xxxx
MP_PUBLIC_KEY=TEST-xxxx

# ─── Render (Gunicorn workers) ────────────────────────────────────────────────
WEB_CONCURRENCY=2
