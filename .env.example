# Banco de Dados
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=delivery_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Envio de Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_verified_sender_email@domain.com

# Envio de mensagem WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# Login Social (Google & Facebook)
# Token provisório – chave DIFERENTE do JWT definitivo para isolamento de escopo
PROVISIONAL_TOKEN_SECRET=your_provisional_token_secret_here
# Tempo de validade do token provisório em minutos (default: 15)
PROVISIONAL_TOKEN_TTL=15
# Timeout (segundos) para chamadas às Graph APIs do Google e Meta (default: 5)
SOCIAL_REQUEST_TIMEOUT=5

# URL base do frontend (usada na geração de links de e-mail)
FRONTEND_URL=http://localhost:3000
